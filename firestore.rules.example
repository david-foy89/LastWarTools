// Example Firestore security rules for optional cross-device sync (account.html).
// Deploy in Firebase Console → Firestore → Rules (merge with your existing rules).
//
// Prerequisites:
// - Authentication → Sign-in method → Email/Password enabled
// - Same Firebase project as firebase-config.js (same projectId as transfer-tracker, etc.)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user JSON blob of localStorage keys (Last War Tools account sync only)
    match /userLocalStorageSync/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Profile: timezone, alliance, server, alliance list, optional avatar (data URL)
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ... keep your existing match blocks for transferSubmissions, etc.
  }
}
