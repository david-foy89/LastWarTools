// Example / documentation: same structure as firestore.rules (merge with transferSubmissions if you split files).
// Deploy: Firebase Console → Firestore → Rules → Publish
//
// Prerequisites: Authentication → Email/Password enabled; same project as firebase-config.js

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Transfer Tracker & Transfer Submit (transfer-tracker.html, transfer-submit.html) ---
    match /transferSubmissions/{docId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    // --- Account: localStorage sync (account.html Sync/Restore; account-sync-global.js on tools) ---
    match /userLocalStorageSync/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Account: profile (account.html; account-nav-chip.js) ---
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Account: usernames (account.html, account-auth-modal.js) ---
    // get only (not list) — app uses getDoc per name; blocks bulk enumeration of email/uid.
    match /usernames/{name} {
      allow get: if true;
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/usernames/$(name))
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
