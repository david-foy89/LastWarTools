rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================================================
    // SECTION: Transfer Tracker & Transfer Submit
    // Pages: transfer-tracker.html, transfer-submit.html
    // Actions: public read; anyone can create/update/delete rows (shared board).
    // Code: collection "transferSubmissions" — listener, setDoc, updateDoc, deleteDoc.
    // =============================================================================
    match /transferSubmissions/{docId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    // =============================================================================
    // SECTION: Rare Soil War Tracker — live collaboration (share link)
    // Page: rare-soil-war-tracker.html — Firestore doc per shareId (same idea as transfer board).
    // Code: collection "rareSoilWarLive" — setDoc / onSnapshot
    // =============================================================================
    match /rareSoilWarLive/{shareId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    // =============================================================================
    // SECTION: Account — localStorage cloud sync
    // Pages: account.html ("Sync now", "Restore to this device")
    //        All calculator pages (silent): account-sync-global.js via page-nav-dropdown.js
    // Actions: read/write only your own doc (document id = Firebase Auth UID).
    // Code: account-sync-lib.js → userLocalStorageSync/{uid}
    //
    // Rare Soil War Tracker (rare-soil-war-tracker.html):
    //   • "Sync to account" stores key lastwar-rare-soil-war-tracker-v1 inside this blob — no
    //     extra Firestore collection or rules block is required.
    //   • Rare Soil War Tracker live link uses Realtime Database only (rare-soil-war/{shareId}).
    //   • Spice War Tracker (spice-war-tracker.html): key lastwar-spice-war-tracker-v1; live RTDB rare-soil-war/spice-{shareId}.
    //   • Copper War Tracker (copper-war-tracker.html): key lastwar-copper-war-tracker-v1; live RTDB rare-soil-war/copper-{shareId}.
    //     This collection is unused by current page code but kept for older clients / experiments.
    // =============================================================================
    match /userLocalStorageSync/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // =============================================================================
    // SECTION: Account — profile (tools read lwProfile* from localStorage after load)
    // Pages: account.html (Save profile, loads on sign-in)
    //        Nav: account-nav-chip.js (avatar / initials on pages that include it)
    // Actions: read/write only your own profile doc.
    // Code: account-profile-lib.js → userProfiles/{uid}
    // =============================================================================
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // =============================================================================
    // SECTION: Account — username registry (username → uid/email for sign-in)
    // Pages: account.html (Create account / Sign in modals)
    //        Calculator pages: account-auth-modal.js (same flows in modal)
    // Actions:
    //   - get: public (single-doc only — isUsernameAvailable / lookup use getDoc; blocks list queries)
    //   - create: only when signed in, doc id unused, uid/email fields set (claimUsernameForNewUser)
    //   - delete: signed-in owner only (account-username-lib.js changeUsernameForUser)
    //   - update: never
    // Code: account-username-lib.js → usernames/{encodeURIComponent(trim(name)) or legacy lowercase key}
    // =============================================================================
    match /usernames/{name} {
      allow get: if true;
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/usernames/$(name))
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string;
      allow update: if false;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // =============================================================================
    // SECTION: Default deny (must be last)
    // Covers any collection not listed above.
    // =============================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
