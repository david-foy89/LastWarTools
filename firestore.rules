rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Transfer tracker + transfer-submit (collection: transferSubmissions).
    // Must stay ABOVE the catch-all deny below. Delete is open (tracker UI); tighten later if needed.
    match /transferSubmissions/{docId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
